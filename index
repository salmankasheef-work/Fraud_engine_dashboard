<script>
  // CLOCK
  function updateClock(){
    const d=new Date();
    document.getElementById('clock').textContent=d.toLocaleTimeString('en-IN',{hour12:true});
  }
  setInterval(updateClock,1000); updateClock();

  // SAMPLE DATA
  const clients=['Client A','Client B','Client C','Flipkart','Meesho','Amazon','Nykaa','Myntra'];
  const hubs=['Mumbai','Delhi','Bangalore','Hyderabad','Chennai','Pune','Kolkata','Ahmedabad'];
  const fraudReasons=['Address Mismatch','CNR Fraud','Fake Return','Empty Box','Tampered Product','Wrong Item Delivered','CX Dispute','Rider Fraud'];
  const statuses=['Open','Closed','RTO Assigned','FPI Investigation','Pending Review'];
  const riskLevels=['High','Medium','Low'];
  const payments=['COD','Prepaid'];
  const assigneeTypes=['RTO Marking','FPI Investigation','Pending Review'];
  const riders=['R-1042','R-2813','R-0071','R-3344','R-1197','R-2200'];

  function randItem(arr){return arr[Math.floor(Math.random()*arr.length)];}
  function randInt(a,b){return Math.floor(Math.random()*(b-a+1))+a;}
  function randAWB(){return 'AWB-'+randItem(['MH','DL','BL','HY','CH'])+randInt(1000000,9999999);}
  function randDate(){
    const d=new Date(); d.setDate(d.getDate()-randInt(0,29));
    return d.toLocaleDateString('en-IN',{day:'2-digit',month:'short',year:'numeric'});
  }

  const allData=Array.from({length:300},(_,i)=>({
    awb:randAWB(), date:randDate(), client:randItem(clients), hub:randItem(hubs),
    risk:randItem(riskLevels), reason:randItem(fraudReasons), status:randItem(statuses),
    payment:randItem(payments), value:'₹'+randInt(200,8000).toLocaleString('en-IN'),
    assign:randItem(assigneeTypes), rider:randItem(riders), attempt:randInt(1,4)
  }));

  let currentPage=1;
  const rowsPerPage=15;
  let filteredData=[...allData];

  function renderTable(data,tbodyId,cols){
    const tbody=document.getElementById(tbodyId);
    if(!tbody)return;
    tbody.innerHTML='';
    data.forEach(r=>{
      const tr=document.createElement('tr');
      tr.onclick=()=>openModal(r);
      tr.innerHTML=cols.map(c=>{
        if(c==='risk')return`<td>${riskBadge(r.risk)}</td>`;
        if(c==='status')return`<td>${statusBadge(r.status)}</td>`;
        if(c==='assign')return`<td><select class="action-select" onclick="event.stopPropagation()"><option>${r.assign}</option><option>RTO Marking</option><option>FPI Investigation</option><option>Pending Review</option></select></td>`;
        if(c==='action')return`<td><button class="chart-btn" onclick="event.stopPropagation();openModal(allData[0])">View</button></td>`;
        if(c==='aging'){const ag=randInt(1,12);return`<td style="color:${ag>7?'var(--red)':ag>4?'var(--orange)':'var(--green)'}">Day ${ag}</td>`;}
        return`<td>${r[c]||''}</td>`;
      }).join('');
      tbody.appendChild(tr);
    });
  }

  function riskBadge(r){
    if(r==='High')return`<span class="risk-badge risk-high">● High</span>`;
    if(r==='Medium')return`<span class="risk-badge risk-med">● Med</span>`;
    return`<span class="risk-badge risk-low">● Low</span>`;
  }
  function statusBadge(s){
    if(s==='Open')return`<span class="status-badge status-open">${s}</span>`;
    if(s==='RTO Assigned')return`<span class="status-badge status-rto">${s}</span>`;
    if(s==='FPI Investigation')return`<span class="status-badge status-fpi">${s}</span>`;
    return`<span class="status-badge status-closed">${s}</span>`;
  }

  function initMainTable(){
    const start=(currentPage-1)*rowsPerPage;
    const pageData=filteredData.slice(start,start+rowsPerPage);
    renderTable(pageData,'main-table-body',['awb','date','client','hub','risk','reason','status','payment','value','assign','action']);
    document.getElementById('page-info').textContent=`${start+1}–${Math.min(start+rowsPerPage,filteredData.length)} of ${filteredData.length.toLocaleString()}`;
  }

  function initFwdTable(){renderTable(allData.slice(0,15),'fwd-table-body',['awb','date','client','hub','risk','reason','status','payment','attempt']);}
  function initRevTable(){renderTable(allData.slice(15,30),'rev-table-body',['awb','date','client','hub','risk','reason','status','rider','attempt']);}
  function initRtoTable(){
    const rows=allData.slice(0,15).map(r=>({...r,type:randItem(['RTO Marking','FPI Investigation']),assignee:randItem(['Rahul S.','Priya M.','Arjun K.','Deepa N.'])}));
    const tbody=document.getElementById('rto-table-body');
    if(!tbody)return;
    tbody.innerHTML='';
    rows.forEach(r=>{
      const tr=document.createElement('tr');tr.onclick=()=>openModal(r);
      const ag=randInt(1,12);
      tr.innerHTML=`<td>${r.awb}</td><td><span class="status-badge ${r.type==='RTO Marking'?'status-rto':'status-fpi'}">${r.type}</span></td><td>${r.hub}</td><td>${r.assignee}</td><td>${riskBadge(r.risk)}</td><td>${statusBadge(r.status)}</td><td>${r.date}</td><td style="color:${ag>7?'var(--red)':ag>4?'var(--orange)':'var(--green)'}">Day ${ag}</td><td><button class="chart-btn" onclick="event.stopPropagation();openModal(allData[0])">View</button></td>`;
      tbody.appendChild(tr);
    });
  }

  function prevPage(){if(currentPage>1){currentPage--;initMainTable();updatePageBtns();}}
  function nextPage(){if(currentPage<Math.ceil(filteredData.length/rowsPerPage)){currentPage++;initMainTable();updatePageBtns();}}
  function goPage(n){currentPage=n;initMainTable();updatePageBtns();}
  function updatePageBtns(){for(let i=1;i<=3;i++){const b=document.getElementById('pg'+i);if(b){b.classList.toggle('active',i===currentPage);b.onclick=()=>goPage(i);}}}

  function filterByAWB(v){
    if(!v){filteredData=[...allData];}else{filteredData=allData.filter(r=>r.awb.toLowerCase().includes(v.toLowerCase()));}
    currentPage=1;initMainTable();
  }
  function searchTable(v){filterByAWB(v);}
  function applyFilter(){initMainTable();}

  // MODAL
  function openModal(r){
    document.getElementById('modal-awb-title').textContent='AWB: '+r.awb;
    const grid=document.getElementById('modal-detail-grid');
    const fields=[['AWB Number',r.awb],['Creation Date',r.date],['Client',r.client],['Hub',r.hub],['Risk Level',r.risk],['Fraud Reason',r.reason],['Order Status',r.status],['Payment Mode',r.payment],['Product Value',r.value],['Attempt #',r.attempt||1],['Rider ID',r.rider||'N/A'],['Assignment',r.assign]];
    grid.innerHTML=fields.map(([k,v])=>`<div class="detail-item"><div class="detail-key">${k}</div><div class="detail-val">${v}</div></div>`).join('');
    document.getElementById('modal-overlay').classList.add('open');
  }
  function closeModal(e){if(e.target.id==='modal-overlay')closeModalDirect();}
  function closeModalDirect(){document.getElementById('modal-overlay').classList.remove('open');}

  // NAVIGATION
  const pages=['overview','forward','reverse','rto','assignments','upload','notifications'];
  const pageTitles={'overview':'Overview Dashboard','forward':'Forward Fraud Data','reverse':'Reverse Fraud Data','rto':'RTO & FPI Investigation','assignments':'Case Assignments','upload':'Upload Center','notifications':'Alerts & Notifications'};
  function showPage(id){
    pages.forEach(p=>{
      const pg=document.getElementById('page-'+p);
      if(pg)pg.classList.toggle('active',p===id);
    });
    document.querySelectorAll('.nav-item').forEach(n=>{
      n.classList.toggle('active',n.getAttribute('onclick')===`showPage('${id}')`);
    });
    document.getElementById('topbar-title').textContent=pageTitles[id]||'Dashboard';
    if(id==='forward')initFwdTable();
    if(id==='reverse')initRevTable();
    if(id==='rto')initRtoTable();
    if(id==='assignments')renderUserChart();
  }

  // UPLOAD HANDLERS
  function dragOver(e,el){e.preventDefault();el.classList.add('drag-over');}
  function dragLeave(e,el){el.classList.remove('drag-over');}
  function drop(e,el,type){e.preventDefault();el.classList.remove('drag-over');processUpload(type,Math.floor(Math.random()*100)+20);}
  function handleUpload(e,type){if(e.target.files[0])processUpload(type,Math.floor(Math.random()*100)+20);}
  function processUpload(type,count){
    const dupes=Math.floor(count*0.1); const updates=Math.floor(count*0.05); const inserts=count-dupes;
    const now=new Date().toLocaleTimeString('en-IN',{hour:'2-digit',minute:'2-digit'});
    document.getElementById('meta-'+type).textContent=`Last upload: Today ${now} · ${count} records`;
    addLog('success',`${type.toUpperCase()} data uploaded — ${inserts} records inserted, ${dupes} duplicates skipped, ${updates} records updated`,now,`+${inserts}`);
    updateUploadStats(count,dupes,0,updates,inserts);
  }
  function addLog(type,text,time,stat){
    const container=document.getElementById('upload-log-container');
    const div=document.createElement('div');div.className='log-row';
    div.innerHTML=`<div class="log-dot ${type}"></div><div><div class="log-text">${text}</div><div class="log-time">Just now · ${time}</div></div><div class="log-stat">${stat}</div>`;
    container.insertBefore(div,container.firstChild);
  }
  function updateUploadStats(total,dupes,failed,updates,inserts){
    const el=id=>parseInt(document.getElementById(id).textContent.replace(/,/g,''));
    document.getElementById('total-uploaded').textContent=(el('total-uploaded')+total).toLocaleString();
    document.getElementById('dupes-removed').textContent=(el('dupes-removed')+dupes).toLocaleString();
    document.getElementById('failed-rows').textContent=(el('failed-rows')+failed).toLocaleString();
    document.getElementById('records-updated').textContent=(el('records-updated')+updates).toLocaleString();
    document.getElementById('new-inserts').textContent=(el('new-inserts')+inserts).toLocaleString();
  }
  function clearLogs(){document.getElementById('upload-log-container').innerHTML='';}

  function exportCSV(){
    const headers=['AWB','Date','Client','Hub','Risk','Reason','Status','Payment','Value'];
    const rows=filteredData.slice(0,100).map(r=>[r.awb,r.date,r.client,r.hub,r.risk,r.reason,r.status,r.payment,r.value].join(','));
    const csv=[headers.join(','),...rows].join('\n');
    const a=document.createElement('a');a.href='data:text/csv;charset=utf-8,'+encodeURIComponent(csv);a.download='fraud_export.csv';a.click();
  }

  // CHARTS
  const CHART_DEFAULTS={responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false}}};
  const gridColor='rgba(255,255,255,0.06)'; const tickColor='#5a6080';

  function makeAxis(opts={}){return{grid:{color:gridColor},ticks:{color:tickColor,font:{size:11}},...opts};}

  function initTrendChart(){
    const labels=Array.from({length:30},(_,i)=>{const d=new Date();d.setDate(d.getDate()-29+i);return d.getDate()+'/'+( d.getMonth()+1);});
    const data=labels.map(()=>randInt(20,90));
    new Chart(document.getElementById('trendChart'),{type:'line',data:{labels,datasets:[{label:'Fraud Cases',data,fill:true,borderColor:'#4f7fff',backgroundColor:'rgba(79,127,255,0.1)',borderWidth:2,pointRadius:0,tension:0.4}]},options:{...CHART_DEFAULTS,scales:{x:{...makeAxis(),ticks:{...makeAxis().ticks,maxTicksLimit:8}},y:makeAxis()}}});
  }

  function initRiskChart(){
