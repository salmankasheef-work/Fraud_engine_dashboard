<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Fraud Engine Dashboard</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=Syne:wght@400;500;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,400&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
<style>
  :root {
    --bg: #0a0c10;
    --bg2: #0e1118;
    --bg3: #141820;
    --bg4: #1a2030;
    --bg5: #1e2535;
    --border: rgba(255,255,255,0.07);
    --border2: rgba(255,255,255,0.12);
    --text: #e8eaf0;
    --text2: #8b91a8;
    --text3: #5a6080;
    --accent: #4f7fff;
    --accent2: #7c5cfc;
    --red: #ff4757;
    --red-bg: rgba(255,71,87,0.12);
    --orange: #ff9f43;
    --orange-bg: rgba(255,159,67,0.12);
    --green: #2ed573;
    --green-bg: rgba(46,213,115,0.12);
    --blue: #4f7fff;
    --blue-bg: rgba(79,127,255,0.12);
    --purple: #7c5cfc;
    --purple-bg: rgba(124,92,252,0.12);
    --cyan: #00d2d3;
    --cyan-bg: rgba(0,210,211,0.12);
    --yellow: #ffd32a;
    --yellow-bg: rgba(255,211,42,0.12);
    --font-head: 'Syne', sans-serif;
    --font-body: 'DM Sans', sans-serif;
    --font-mono: 'IBM Plex Mono', monospace;
    --radius: 10px;
    --radius-lg: 16px;
    --shadow: 0 4px 24px rgba(0,0,0,0.4);
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { background: var(--bg); color: var(--text); font-family: var(--font-body); font-size: 14px; min-height: 100vh; overflow-x: hidden; }

  /* LAYOUT */
  .layout { display: flex; min-height: 100vh; }
  .sidebar { width: 220px; background: var(--bg2); border-right: 1px solid var(--border); display: flex; flex-direction: column; position: fixed; top: 0; left: 0; height: 100vh; z-index: 100; overflow-y: auto; }
  .main { margin-left: 220px; flex: 1; display: flex; flex-direction: column; }
  .topbar { background: var(--bg2); border-bottom: 1px solid var(--border); padding: 0 24px; height: 58px; display: flex; align-items: center; gap: 16px; position: sticky; top: 0; z-index: 50; }
  .content { padding: 24px; flex: 1; }

  /* SIDEBAR */
  .logo { padding: 18px 20px 16px; border-bottom: 1px solid var(--border); }
  .logo-text { font-family: var(--font-head); font-size: 17px; font-weight: 800; background: linear-gradient(135deg, var(--accent), var(--accent2)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; letter-spacing: -0.3px; }
  .logo-sub { font-size: 10px; color: var(--text3); font-family: var(--font-mono); letter-spacing: 1.5px; text-transform: uppercase; margin-top: 2px; }
  .nav-section { padding: 16px 12px 8px; }
  .nav-label { font-size: 10px; color: var(--text3); font-family: var(--font-mono); letter-spacing: 1.5px; text-transform: uppercase; padding: 0 8px; margin-bottom: 6px; }
  .nav-item { display: flex; align-items: center; gap: 10px; padding: 9px 12px; border-radius: var(--radius); cursor: pointer; color: var(--text2); font-size: 13.5px; font-weight: 400; transition: all 0.15s; margin-bottom: 2px; position: relative; }
  .nav-item:hover { background: var(--bg4); color: var(--text); }
  .nav-item.active { background: var(--blue-bg); color: var(--accent); font-weight: 500; }
  .nav-item.active::before { content: ''; position: absolute; left: 0; top: 50%; transform: translateY(-50%); height: 60%; width: 3px; background: var(--accent); border-radius: 0 3px 3px 0; }
  .nav-item i { width: 16px; text-align: center; font-size: 14px; }
  .nav-badge { margin-left: auto; background: var(--red-bg); color: var(--red); font-size: 10px; font-family: var(--font-mono); padding: 2px 6px; border-radius: 20px; }
  .sidebar-footer { margin-top: auto; padding: 16px; border-top: 1px solid var(--border); }
  .user-row { display: flex; align-items: center; gap: 10px; }
  .user-avatar { width: 30px; height: 30px; border-radius: 50%; background: linear-gradient(135deg, var(--accent), var(--accent2)); display: flex; align-items: center; justify-content: center; font-size: 11px; font-weight: 700; color: #fff; }
  .user-name { font-size: 13px; font-weight: 500; }
  .user-role { font-size: 11px; color: var(--text3); }
  .role-badge { font-size: 9px; font-family: var(--font-mono); padding: 2px 7px; border-radius: 20px; background: var(--purple-bg); color: var(--purple); margin-left: 6px; vertical-align: middle; }

  /* TOPBAR */
  .topbar-title { font-family: var(--font-head); font-size: 16px; font-weight: 700; margin-right: auto; }
  .search-wrap { position: relative; }
  .search-wrap input { background: var(--bg3); border: 1px solid var(--border); border-radius: 8px; padding: 7px 12px 7px 32px; color: var(--text); font-size: 13px; width: 220px; outline: none; font-family: var(--font-body); }
  .search-wrap input:focus { border-color: var(--accent); }
  .search-wrap input::placeholder { color: var(--text3); }
  .search-icon { position: absolute; left: 10px; top: 50%; transform: translateY(-50%); color: var(--text3); font-size: 12px; }
  .topbar-btn { background: var(--bg3); border: 1px solid var(--border); border-radius: 8px; padding: 7px 14px; color: var(--text2); font-size: 13px; cursor: pointer; display: flex; align-items: center; gap: 7px; font-family: var(--font-body); transition: all 0.15s; }
  .topbar-btn:hover { border-color: var(--border2); color: var(--text); }
  .topbar-btn.primary { background: var(--accent); border-color: var(--accent); color: #fff; }
  .live-dot { width: 7px; height: 7px; border-radius: 50%; background: var(--green); animation: pulse 2s infinite; }
  @keyframes pulse { 0%,100%{opacity:1;} 50%{opacity:0.4;} }
  .topbar-time { font-family: var(--font-mono); font-size: 12px; color: var(--text3); }

  /* TABS */
  .tabs { display: flex; gap: 0; border-bottom: 1px solid var(--border); margin-bottom: 22px; }
  .tab { padding: 10px 20px; cursor: pointer; font-size: 13.5px; color: var(--text2); border-bottom: 2px solid transparent; margin-bottom: -1px; transition: all 0.15s; font-weight: 400; }
  .tab:hover { color: var(--text); }
  .tab.active { color: var(--accent); border-bottom-color: var(--accent); font-weight: 500; }

  /* SUB TABS */
  .sub-tabs { display: flex; gap: 8px; margin-bottom: 20px; }
  .sub-tab { padding: 7px 18px; border-radius: 8px; cursor: pointer; font-size: 13px; color: var(--text2); background: var(--bg3); border: 1px solid var(--border); transition: all 0.15s; }
  .sub-tab:hover { border-color: var(--border2); color: var(--text); }
  .sub-tab.active { background: var(--blue-bg); color: var(--accent); border-color: rgba(79,127,255,0.3); }

  /* FILTER BAR */
  .filter-bar { display: flex; gap: 10px; margin-bottom: 20px; align-items: center; flex-wrap: wrap; }
  .filter-bar select, .filter-bar input[type=date] { background: var(--bg3); border: 1px solid var(--border); border-radius: 8px; padding: 7px 12px; color: var(--text2); font-size: 12.5px; outline: none; font-family: var(--font-body); cursor: pointer; appearance: none; -webkit-appearance: none; }
  .filter-bar select:focus, .filter-bar input:focus { border-color: var(--accent); color: var(--text); }
  .filter-wrap { position: relative; }
  .filter-wrap::after { content: '\f107'; font-family: 'Font Awesome 6 Free'; font-weight: 900; position: absolute; right: 10px; top: 50%; transform: translateY(-50%); color: var(--text3); font-size: 11px; pointer-events: none; }
  .filter-label { font-size: 12px; color: var(--text3); }
  .date-range { display: flex; align-items: center; gap: 6px; }
  .clear-btn { padding: 7px 14px; border-radius: 8px; background: transparent; border: 1px solid var(--border); color: var(--text3); font-size: 12px; cursor: pointer; font-family: var(--font-body); }
  .clear-btn:hover { border-color: var(--border2); color: var(--text); }

  /* KPI CARDS */
  .kpi-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(155px, 1fr)); gap: 12px; margin-bottom: 22px; }
  .kpi-card { background: var(--bg3); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 14px 16px; position: relative; overflow: hidden; transition: transform 0.15s, border-color 0.15s; cursor: default; }
  .kpi-card:hover { transform: translateY(-2px); border-color: var(--border2); }
  .kpi-card::before { content: ''; position: absolute; top: 0; right: 0; width: 60px; height: 60px; border-radius: 0 0 0 60px; opacity: 0.07; }
  .kpi-card.red::before { background: var(--red); }
  .kpi-card.orange::before { background: var(--orange); }
  .kpi-card.green::before { background: var(--green); }
  .kpi-card.blue::before { background: var(--blue); }
  .kpi-card.purple::before { background: var(--purple); }
  .kpi-card.cyan::before { background: var(--cyan); }
  .kpi-card.yellow::before { background: var(--yellow); }
  .kpi-label { font-size: 11px; color: var(--text3); text-transform: uppercase; letter-spacing: 0.8px; font-family: var(--font-mono); margin-bottom: 8px; }
  .kpi-value { font-family: var(--font-head); font-size: 26px; font-weight: 700; line-height: 1; margin-bottom: 6px; }
  .kpi-card.red .kpi-value { color: var(--red); }
  .kpi-card.orange .kpi-value { color: var(--orange); }
  .kpi-card.green .kpi-value { color: var(--green); }
  .kpi-card.blue .kpi-value { color: var(--blue); }
  .kpi-card.purple .kpi-value { color: var(--purple); }
  .kpi-card.cyan .kpi-value { color: var(--cyan); }
  .kpi-card.yellow .kpi-value { color: var(--yellow); }
  .kpi-card.white .kpi-value { color: var(--text); }
  .kpi-delta { font-size: 11px; display: flex; align-items: center; gap: 4px; }
  .kpi-delta.up { color: var(--green); }
  .kpi-delta.down { color: var(--red); }
  .kpi-icon { position: absolute; top: 14px; right: 14px; font-size: 18px; opacity: 0.3; }
  .kpi-card.red .kpi-icon { color: var(--red); }
  .kpi-card.orange .kpi-icon { color: var(--orange); }
  .kpi-card.green .kpi-icon { color: var(--green); }
  .kpi-card.blue .kpi-icon { color: var(--blue); }
  .kpi-card.purple .kpi-icon { color: var(--purple); }
  .kpi-card.cyan .kpi-icon { color: var(--cyan); }

  /* CHART SECTIONS */
  .chart-grid { display: grid; gap: 16px; margin-bottom: 22px; }
  .chart-grid-2 { grid-template-columns: 1fr 1fr; }
  .chart-grid-3 { grid-template-columns: 2fr 1fr 1fr; }
  .chart-card { background: var(--bg3); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 18px; }
  .chart-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16px; }
  .chart-title { font-family: var(--font-head); font-size: 14px; font-weight: 600; color: var(--text); }
  .chart-subtitle { font-size: 11px; color: var(--text3); margin-top: 2px; }
  .chart-actions { display: flex; gap: 6px; }
  .chart-btn { background: var(--bg4); border: 1px solid var(--border); border-radius: 6px; padding: 4px 10px; font-size: 11px; color: var(--text3); cursor: pointer; font-family: var(--font-mono); transition: all 0.12s; }
  .chart-btn:hover, .chart-btn.active { background: var(--blue-bg); color: var(--accent); border-color: rgba(79,127,255,0.3); }
  .canvas-wrap { position: relative; }

  /* TABLE */
  .table-card { background: var(--bg3); border: 1px solid var(--border); border-radius: var(--radius-lg); overflow: hidden; margin-bottom: 22px; }
  .table-header { display: flex; align-items: center; justify-content: space-between; padding: 16px 18px; border-bottom: 1px solid var(--border); }
  .table-search { background: var(--bg4); border: 1px solid var(--border); border-radius: 7px; padding: 6px 12px 6px 30px; color: var(--text); font-size: 12.5px; outline: none; font-family: var(--font-body); width: 200px; position: relative; }
  .table-search-wrap { position: relative; }
  .table-search-wrap i { position: absolute; left: 10px; top: 50%; transform: translateY(-50%); color: var(--text3); font-size: 11px; }
  .table-wrap { overflow-x: auto; }
  table { width: 100%; border-collapse: collapse; }
  thead th { padding: 10px 14px; text-align: left; font-size: 11px; font-family: var(--font-mono); color: var(--text3); text-transform: uppercase; letter-spacing: 0.8px; border-bottom: 1px solid var(--border); white-space: nowrap; }
  tbody tr { border-bottom: 1px solid var(--border); transition: background 0.1s; cursor: pointer; }
  tbody tr:last-child { border-bottom: none; }
  tbody tr:hover { background: var(--bg4); }
  tbody td { padding: 11px 14px; font-size: 13px; color: var(--text2); white-space: nowrap; }
  tbody td:first-child { font-family: var(--font-mono); font-size: 12px; color: var(--accent); }
  .risk-badge { display: inline-flex; align-items: center; gap: 5px; padding: 3px 10px; border-radius: 20px; font-size: 11px; font-weight: 500; font-family: var(--font-mono); }
  .risk-high { background: var(--red-bg); color: var(--red); }
  .risk-med { background: var(--orange-bg); color: var(--orange); }
  .risk-low { background: var(--green-bg); color: var(--green); }
  .status-badge { display: inline-flex; align-items: center; gap: 5px; padding: 3px 10px; border-radius: 20px; font-size: 11px; font-family: var(--font-mono); }
  .status-open { background: var(--blue-bg); color: var(--accent); }
  .status-closed { background: rgba(255,255,255,0.05); color: var(--text3); }
  .status-rto { background: var(--purple-bg); color: var(--purple); }
  .status-fpi { background: var(--cyan-bg); color: var(--cyan); }
  .action-select { background: var(--bg4); border: 1px solid var(--border); border-radius: 6px; padding: 4px 8px; color: var(--text2); font-size: 11px; font-family: var(--font-mono); outline: none; cursor: pointer; }
  .pagination { display: flex; align-items: center; gap: 6px; padding: 12px 18px; border-top: 1px solid var(--border); justify-content: flex-end; }
  .page-btn { width: 30px; height: 30px; border-radius: 7px; background: var(--bg4); border: 1px solid var(--border); color: var(--text2); font-size: 12px; cursor: pointer; display: flex; align-items: center; justify-content: center; font-family: var(--font-mono); transition: all 0.12s; }
  .page-btn:hover, .page-btn.active { background: var(--blue-bg); color: var(--accent); border-color: rgba(79,127,255,0.3); }
  .page-info { font-size: 12px; color: var(--text3); font-family: var(--font-mono); }

  /* UPLOAD CENTER */
  .upload-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 16px; margin-bottom: 22px; }
  .upload-card { background: var(--bg3); border: 1px dashed var(--border2); border-radius: var(--radius-lg); padding: 24px; text-align: center; cursor: pointer; transition: all 0.2s; position: relative; overflow: hidden; }
  .upload-card:hover { border-color: var(--accent); background: var(--bg4); }
  .upload-card.drag-over { border-color: var(--accent); background: var(--blue-bg); }
  .upload-icon { font-size: 32px; margin-bottom: 12px; }
  .upload-card.forward .upload-icon { color: var(--blue); }
  .upload-card.reverse .upload-icon { color: var(--orange); }
  .upload-card.rto .upload-icon { color: var(--purple); }
  .upload-card.fpi .upload-icon { color: var(--cyan); }
  .upload-card.history .upload-icon { color: var(--green); }
  .upload-title { font-family: var(--font-head); font-size: 15px; font-weight: 600; margin-bottom: 6px; }
  .upload-desc { font-size: 12px; color: var(--text3); margin-bottom: 14px; }
  .upload-btn { display: inline-block; background: var(--bg4); border: 1px solid var(--border); border-radius: 7px; padding: 7px 18px; font-size: 12px; color: var(--text2); transition: all 0.15s; cursor: pointer; }
  .upload-card:hover .upload-btn { background: var(--accent); border-color: var(--accent); color: #fff; }
  .upload-meta { font-size: 11px; color: var(--text3); font-family: var(--font-mono); margin-top: 10px; }
  .upload-log { background: var(--bg3); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 18px; }
  .log-row { display: flex; align-items: flex-start; gap: 12px; padding: 10px 0; border-bottom: 1px solid var(--border); font-size: 12.5px; }
  .log-row:last-child { border-bottom: none; }
  .log-dot { width: 8px; height: 8px; border-radius: 50%; margin-top: 4px; flex-shrink: 0; }
  .log-dot.success { background: var(--green); }
  .log-dot.warn { background: var(--orange); }
  .log-dot.error { background: var(--red); }
  .log-time { font-family: var(--font-mono); font-size: 11px; color: var(--text3); white-space: nowrap; }
  .log-text { color: var(--text2); }
  .log-stat { margin-left: auto; font-family: var(--font-mono); font-size: 11px; color: var(--text3); white-space: nowrap; }

  /* RTO/FPI */
  .progress-track { background: var(--bg4); border-radius: 20px; height: 8px; overflow: hidden; margin-top: 6px; }
  .progress-fill { height: 100%; border-radius: 20px; transition: width 0.5s ease; }
  .aging-row { display: flex; align-items: center; gap: 10px; padding: 8px 0; border-bottom: 1px solid var(--border); font-size: 12.5px; }
  .aging-bar { flex: 1; height: 6px; background: var(--bg4); border-radius: 20px; overflow: hidden; }
  .aging-fill { height: 100%; border-radius: 20px; }

  /* PAGE VISIBILITY */
  .page { display: none; }
  .page.active { display: block; }

  /* NOTIFICATION PANEL */
  .notif-panel { background: var(--bg3); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 16px; margin-bottom: 20px; }
  .notif-item { display: flex; gap: 12px; padding: 10px 0; border-bottom: 1px solid var(--border); align-items: flex-start; }
  .notif-item:last-child { border-bottom: none; }
  .notif-icon { width: 34px; height: 34px; border-radius: 8px; display: flex; align-items: center; justify-content: center; font-size: 14px; flex-shrink: 0; }
  .notif-icon.red { background: var(--red-bg); color: var(--red); }
  .notif-icon.orange { background: var(--orange-bg); color: var(--orange); }
  .notif-icon.green { background: var(--green-bg); color: var(--green); }
  .notif-icon.blue { background: var(--blue-bg); color: var(--blue); }
  .notif-text { font-size: 13px; color: var(--text2); line-height: 1.5; }
  .notif-time { font-size: 11px; color: var(--text3); font-family: var(--font-mono); margin-top: 3px; }

  /* MINI SPARKLINE */
  .sparkline { height: 36px; }

  /* SECTION HEADER */
  .section-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 14px; }
  .section-title { font-family: var(--font-head); font-size: 15px; font-weight: 600; }
  .see-all { font-size: 12px; color: var(--accent); cursor: pointer; display: flex; align-items: center; gap: 4px; }

  /* STAT ROW */
  .stat-row { display: flex; align-items: center; justify-content: space-between; padding: 8px 0; border-bottom: 1px solid var(--border); font-size: 13px; }
  .stat-row:last-child { border-bottom: none; }
  .stat-label { color: var(--text2); }
  .stat-val { font-family: var(--font-mono); font-weight: 500; }

  /* SCROLLBAR */
  ::-webkit-scrollbar { width: 4px; height: 4px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: var(--bg5); border-radius: 4px; }
  ::-webkit-scrollbar-thumb:hover { background: var(--text3); }

  /* AWB DETAIL MODAL */
  .modal-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.75); z-index: 200; display: none; align-items: center; justify-content: center; backdrop-filter: blur(4px); }
  .modal-overlay.open { display: flex; }
  .modal { background: var(--bg2); border: 1px solid var(--border2); border-radius: var(--radius-lg); padding: 24px; width: 580px; max-height: 85vh; overflow-y: auto; }
  .modal-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 20px; }
  .modal-title { font-family: var(--font-head); font-size: 17px; font-weight: 700; }
  .modal-close { width: 30px; height: 30px; border-radius: 7px; background: var(--bg4); border: 1px solid var(--border); color: var(--text2); cursor: pointer; display: flex; align-items: center; justify-content: center; font-size: 13px; }
  .detail-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 16px; }
  .detail-item { background: var(--bg3); border-radius: var(--radius); padding: 12px; }
  .detail-key { font-size: 10px; color: var(--text3); font-family: var(--font-mono); text-transform: uppercase; letter-spacing: 0.8px; margin-bottom: 4px; }
  .detail-val { font-size: 14px; color: var(--text); font-weight: 500; }
  .notes-area { background: var(--bg3); border: 1px solid var(--border); border-radius: var(--radius); padding: 12px; width: 100%; min-height: 80px; color: var(--text); font-size: 13px; font-family: var(--font-body); resize: vertical; margin-bottom: 12px; outline: none; }
  .notes-area:focus { border-color: var(--accent); }
  .save-btn { background: var(--accent); border: none; border-radius: 8px; padding: 9px 24px; color: #fff; font-size: 13px; font-weight: 500; cursor: pointer; font-family: var(--font-body); }
  .save-btn:hover { opacity: 0.9; }

  /* RESPONSIVE */
  @media (max-width: 900px) {
    .sidebar { width: 56px; }
    .nav-label, .nav-item span, .user-name, .user-role, .logo-sub { display: none; }
    .logo-text { font-size: 14px; }
    .main { margin-left: 56px; }
    .chart-grid-2, .chart-grid-3 { grid-template-columns: 1fr; }
  }
</style>
</head>
<body>

<div class="layout">
  <!-- SIDEBAR -->
