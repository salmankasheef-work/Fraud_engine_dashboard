    <textarea class="notes-area" placeholder="Add investigation notes, comments, or updates here..."></textarea>
    <div style="display:flex;gap:10px">
      <select class="action-select" style="padding:9px 12px;border-radius:8px;font-size:13px">
        <option>Pending Review</option>
        <option>RTO Marking</option>
        <option>FPI Investigation</option>
        <option>Closed</option>
      </select>
      <button class="save-btn"><i class="fa fa-floppy-disk"></i> Save Changes</button>
